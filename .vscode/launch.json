{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run CodeShield Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/frontend"
            ],
            "outFiles": [
                "${workspaceFolder}/frontend/out/**/*.js"
            ]
        }
    ]
}