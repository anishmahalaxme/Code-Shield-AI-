{
  "name": "codeshield-ai-security",
  "displayName": "CodeShield Security",
  "description": "Real-time vulnerability detection powered by AI",
  "version": "0.1.6",
  "publisher": "AnishMahalaxme",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anishmahalaxme/Code-Shield-AI-"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:csharp",
    "onLanguage:go",
    "onLanguage:php",
    "onLanguage:ruby",
    "onLanguage:sql",
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "CodeShield",
      "properties": {
        "codeshield.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Base URL of the CodeShield API (uvicorn). Start it from the repo: backend/start.sh. If NO API persists, confirm this URL matches where the server listens."
        },
        "codeshield.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "If the API is down, automatically run backend/start.sh when the workspace folder contains backend/app/main.py (this repo)."
        }
      }
    },
    "commands": [
      {
        "command": "codeshield.pingApi",
        "title": "CodeShield: Test API Connection"
      },
      {
        "command": "codeshield.analyze",
        "title": "Run CodeShield Scan"
      },
      {
        "command": "codeshield.applyFix",
        "title": "⚡ Auto-Fix Code"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeshield-container",
          "title": "CodeShield",
          "icon": "media/shield.svg"
        }
      ]
    },
    "views": {
      "codeshield-container": [
        {
          "type": "webview",
          "id": "codeshield.sidebar",
          "name": "CodeShield Security",
          "icon": "media/shield.svg"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}